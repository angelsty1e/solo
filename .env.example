# ─── solo — configuration ────────────────────────────────────────────────────
# Copy to `.env` to override. Every value has a sane default; an empty `.env`
# (or none at all) still gives a fully working `docker compose up -d`.

# HTTP/TLS
PORT=8443
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# Common Name used for the auto-generated self-signed certificate (entrypoint).
# Set it to your LXC hostname so browsers show the right name.
TLS_CN=localhost

# TLS material (inside the container). Leave as-is to use the auto-generated
# self-signed cert; drop your own cert.pem/key.pem in ./certs to override.
CERT_PATH=/certs/cert.pem
KEY_PATH=/certs/key.pem

# Persistent data (SQLite + optional MaxMind/Tor files), inside the container.
DB_PATH=/data/solo.db
GEOIP_DB=/data/GeoLite2-ASN.mmdb
GEOIP_COUNTRY_DB=/data/GeoLite2-Country.mmdb
TOR_EXIT_LIST=/data/tor-exit-nodes.txt

# MaxMind integrity pinning (audit-hardening P2 — OPT-IN, fail-closed). The
# .mmdb parser reads an attacker-influenceable binary; pin its SHA-256 so a
# tampered/swapped base refuses to load (the server throws on mismatch) instead
# of being parsed silently. Leave empty to skip the check. Compute once after an
# official MaxMind download:
#   sha256sum data/GeoLite2-ASN.mmdb data/GeoLite2-Country.mmdb
# GEOIP_DB_SHA256=
# GEOIP_COUNTRY_DB_SHA256=

# NOTE — there is currently NO application-level authentication. The data
# endpoints (/api/fp/:id, /export/:id) are protected only by the unguessable
# server-generated UUID in the URL; /collect is open and rate-limited. Run the
# lab behind network isolation (LXC firewall / reverse proxy) for any exposure.
# (The previous SESSION_SECRET / ADMIN_TOKEN placeholders were removed: nothing
# in the code read them, so setting one gave a false sense of protection.)
