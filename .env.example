# ─── solo — configuration ────────────────────────────────────────────────────
# Copy to `.env` to override. Every value has a sane default; an empty `.env`
# (or none at all) still gives a fully working `docker compose up -d`.

# HTTP/TLS
PORT=8443
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# Common Name used for the auto-generated self-signed certificate (entrypoint).
# Set it to your LXC hostname so browsers show the right name.
TLS_CN=localhost

# TLS material (inside the container). Leave as-is to use the auto-generated
# self-signed cert; drop your own cert.pem/key.pem in ./certs to override.
CERT_PATH=/certs/cert.pem
KEY_PATH=/certs/key.pem

# Persistent data (SQLite + optional MaxMind/Tor files), inside the container.
DB_PATH=/data/solo.db
GEOIP_DB=/data/GeoLite2-ASN.mmdb
GEOIP_COUNTRY_DB=/data/GeoLite2-Country.mmdb
TOR_EXIT_LIST=/data/tor-exit-nodes.txt

# Secret used to sign nothing critical today, reserved for future signed cookies.
# If empty, a random one is generated at boot (invalidated on restart).
SESSION_SECRET=

# Optional admin bearer token. If set, unlocks future privileged endpoints.
ADMIN_TOKEN=
