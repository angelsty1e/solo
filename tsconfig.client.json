{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "jsx": "preserve"
  },
  "include": ["src/client/**/*.ts", "src/ui/**/*.ts", "src/shared/**/*.ts"]
}
